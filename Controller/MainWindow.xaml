<Window x:Class="Controller.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Controller"
        Title="Remote Desktop Controller"
        Width="1200" Height="800"
        MinWidth="900" MinHeight="600"
        Background="{StaticResource BackgroundPrimaryBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="10,8">
                <TextBlock Text="Remote Desktop Controller"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                <Button x:Name="ConnectButton" Content="Connect"
                        Style="{StaticResource ModernButtonStyle}"
                        Width="90" Height="30" Margin="20,0,0,0"
                        Click="ConnectButton_Click"/>
                <Button x:Name="DisconnectButton" Content="Disconnect"
                        Style="{StaticResource ModernButtonStyle}"
                        Width="90" Height="30" Margin="10,0,0,0"
                        Click="DisconnectButton_Click" IsEnabled="False"/>
                <Button x:Name="TransferFileButton" Content="Send File"
                        Style="{StaticResource ModernButtonStyle}"
                        Width="90" Height="30" Margin="10,0,0,0"
                        Click="TransferFileButton_Click" IsEnabled="False"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="10">
                <StackPanel>
                    <TextBlock Text="Connection"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <TextBlock Text="Host:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="HostTextBox" Text="127.0.0.1"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Port:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="PortTextBox" Text="8080"
                             Style="{StaticResource ModernTextBoxStyle}"
                             Margin="0,0,0,10"/>

                    <TextBlock Text="Password:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,0,0,5"/>
                    <PasswordBox x:Name="PasswordBox"
                                 Margin="0,0,0,15"
                                 Background="{StaticResource BackgroundSecondaryBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource BorderBrush}"/>

                    <Border Background="{StaticResource BackgroundPrimaryBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Status"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="12"/>
                            <local:StatusIndicator x:Name="ConnectionStatus"
                                                   Width="40" Height="40"
                                                   HorizontalAlignment="Left"
                                                   Margin="0,10,0,0"
                                                   Status="Gray"/>
                        </StackPanel>
                    </Border>

                    <TextBlock x:Name="StatusText" Text="Disconnected"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,15,0,0"
                               TextWrapping="Wrap"/>

                    <TextBlock x:Name="ResolutionText" Text=""
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="0,10">
                <Grid>
                    <Image x:Name="ScreenImage"
                           Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           MouseMove="ScreenImage_MouseMove"
                           MouseLeftButtonDown="ScreenImage_MouseLeftButtonDown"
                           MouseLeftButtonUp="ScreenImage_MouseLeftButtonUp"/>
                    <TextBlock x:Name="NoSignalText" Text="No Signal"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="24" HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="10">
                <StackPanel>
                    <TextBlock Text="File Transfer"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>

                    <ListBox x:Name="TransferListBox"
                             Background="{StaticResource BackgroundPrimaryBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Height="150" Margin="0,0,0,10"/>

                    <TextBlock x:Name="TransferStatusText" Text=""
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12" TextWrapping="Wrap"/>

                    <ProgressBar x:Name="TransferProgress"
                                 Height="20" Margin="0,10,0,0"
                                 Background="{StaticResource BackgroundPrimaryBrush}"
                                 Foreground="{StaticResource AccentPrimaryBrush}"
                                 Visibility="Collapsed"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BackgroundSecondaryBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="10,5">
                <TextBlock x:Name="InfoText" Text="Ready"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
