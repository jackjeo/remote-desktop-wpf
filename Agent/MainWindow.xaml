<Window x:Class="Agent.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Agent"
        Title="Remote Desktop Agent"
        Width="400" Height="300"
        Background="{StaticResource BackgroundPrimaryBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,20,0,20">
            <TextBlock Text="Remote Desktop Agent"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontSize="24" FontWeight="Bold"/>
            <TextBlock x:Name="StatusText" Text="Initializing..."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="14" Margin="0,10,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <local:StatusIndicator Grid.Row="1"
                               x:Name="ConnectionStatus"
                               Width="80" Height="80"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Status="Gray"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <TextBlock Text="Port: "
                       Foreground="{StaticResource TextSecondaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBox x:Name="PortTextBox" Text="8080"
                     Width="80"
                     Style="{StaticResource ModernTextBoxStyle}"/>
            <Button x:Name="StartButton" Content="Start"
                    Style="{StaticResource ModernButtonStyle}"
                    Width="80" Height="32" Margin="10,0,0,0"
                    Click="StartButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
